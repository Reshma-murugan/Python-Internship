    "import string\n",
    "\n",
    "def remove(str):\n",
    "    result=\"\"\n",
    "    for ch in str:\n",
    "        if ch not in string.punctuation:\n",
    "            result+=ch\n",
    "    return result\n",
    "str=input(\"enter the string\")        \n",
    "print(remove(str))"
   ]
  }

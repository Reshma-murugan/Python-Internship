   "source": [
    "def is_unique(str):\n",
    "    seen=set()\n",
    "    for ch in str:\n",
    "        if ch in seen:\n",
    "            return False\n",
    "        seen.add(ch)    \n",
    "    return True  \n",
    "if is_unique(\"RESHMA\"):\n",
    "    print(\"unique\")   \n",
    "else:\n",
    "    print(\"not unique\")    "
   ]
  }

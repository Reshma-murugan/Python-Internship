   "source": [
    "def is_palindrome(l):\n",
    "    length = len(l)\n",
    "    for i in range(length // 2):\n",
    "        if l[i] != l[length - 1 - i]:\n",
    "            return False\n",
    "    return True    \n",
    "\n",
    "L = [\"a\", \"p\", \"p\", \"a\"]\n",
    "\n",
    "if is_palindrome(L):\n",
    "    print(\"palindrome\")    \n",
    "else:\n",
    "    print(\"not a palindrome\")"
   ]
  }
 ],

    "def rev_str(str):\n",
    "    rev=\"\"\n",
    "    for ch in str:\n",
    "        rev=ch+rev\n",
    "    return rev\n",
    "str=input(\"enter a string\")  \n",
    "print(rev_str(str))\n"
   ]
  }

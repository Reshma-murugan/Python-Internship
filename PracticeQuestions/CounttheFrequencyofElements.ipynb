    "def count(L):\n",
    "    D={ }\n",
    "    for x in L:\n",
    "        if x not in D:\n",
    "            D[x]=1\n",
    "        else:\n",
    "            D[x]+=1\n",
    "    print(D)        \n",
    "nums = input(\"Enter numbers: \") \n",
    "count(nums)          "
   ]
  }

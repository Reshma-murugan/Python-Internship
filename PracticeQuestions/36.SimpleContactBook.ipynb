    "def search(name):\n",
    "    D={\"Ravi\": \"9876543210\", \"Anu\": \"9911223344\"}\n",
    "    if name in D:\n",
    "        return f\"Contact: {D[name]}\"\n",
    "    else:\n",
    "        return \"Contact not found\"\n",
    "print(search(\"Anu\"))     "
   ]

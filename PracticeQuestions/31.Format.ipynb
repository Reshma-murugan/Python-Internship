   "source": [
    "import re  # Python's regex module\n",
    "\n",
    "def validate_pan(text):\n",
    "    pattern = r\"^[A-Z]{5}[0-9]{4}[A-Z]$\"  # PAN format\n",
    "    if re.match(pattern, text):\n",
    "        print(\"Valid PAN\")\n",
    "    else:\n",
    "        print(\"Invalid PAN\")\n",
    "\n",
    "pan = \"ABCDE1234F\"\n",
    "validate_pan(pan)"
   ]
  }

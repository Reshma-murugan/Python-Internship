   "source": [
    "def digi_count(num):\n",
    "    count=0\n",
    "    while num!=0:\n",
    "        digit=num%10\n",
    "        count=count+digit\n",
    "        num=num//10\n",
    "    return count\n",
    "\n",
    "digi_count(1234)    \n"
   ]
  }

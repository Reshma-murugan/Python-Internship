   "source": [
    "def flatten_list(nested_list):\n",
    "    flat_list=[]\n",
    "    for i in nested_list:\n",
    "        for j in i:\n",
    "            flat_list.append(j)\n",
    "    return flat_list\n",
    "nested_list = [[1, 2], [3, 4], [5]]\n",
    "print(flatten_list(nested_list))            "
   ]
  }

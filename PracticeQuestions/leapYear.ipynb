   ],
   "source": [
    "def is_leapYear(year):\n",
    "    if (year%4==0 and year%100!=0) or year%400==0:\n",
    "        print(\"leap year\")\n",
    "    else:\n",
    "        print(\"not a leap year\")   \n",
    "\n",
    "year=int(input(\"enter year\"))\n",
    "is_leapYear(year)"
   ]
  }

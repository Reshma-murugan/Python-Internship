   "source": [
    "def list_sum(lst):\n",
    "    total = 0\n",
    "    for i in lst:\n",
    "        total += i\n",
    "    return total\n",
    "\n",
    "lst = list(map(int, input(\"Enter the numbers: \").split()))\n",
    "print(list_sum(lst))"
   ]
  }
